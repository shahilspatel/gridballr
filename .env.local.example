SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ===== STRIPE TEST MODE =====
STRIPE_SECRET_KEY=sk_test_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_your_test_price_id

# ===== EXTERNAL APIs =====
YOUTUBE_API_KEY=your-youtube-api-key
CFBD_API_KEY=your-cfbd-api-key

# ===== APP =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== AUTH FEATURE FLAGS =====
# Set to "true" once Google OAuth is wired in Supabase + GCP Console.
# Default off — the button is hidden everywhere until then.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# ===== ERROR TRACKING (optional) =====
# Get a DSN from https://sentry.io → Create Project → Next.js
# Sentry only initializes when NODE_ENV=production AND this is set.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oxxxxx.ingest.sentry.io/xxxxx

# ===== CRON =====
# Random high-entropy secret for /api/cron/stale-check authorization.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me-with-32-bytes-of-random-hex
# ISO date string of last prospect data refresh — used by stale-check cron.
PROSPECT_DATA_LAST_UPDATED=2026-04-09

# ===== PRODUCTION (replace local values above) =====
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-prod-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_APP_URL=https://gridballr.com
